# Copy this to .env and fill in your values.
# On Vercel, set these in Project Settings → Environment Variables.

# Helius RPC API key (used by api/collect.js for server-side RPC calls)
HELIUS_API_KEY=

# Solana RPC endpoint (used by api/rpc.js)
SOLANA_RPC=

# Supabase connection (used by api/collect.js, api/snapshots.js, api/track-validator.js)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Secret for cron-triggered collection (used by api/collect.js).
# Collect snapshots all mainnet vote accounts from RPC each run (not only manually tracked keys).
CRON_SECRET=
